{
  "name": "cdk-spilman-kit",
  "version": "0.1.0",
  "description": "Spilman channel management kit for Express",
  "type": "module",
  "scripts": {
    "build": "tsc --incremental",
    "server": "tsx src/example_server.ts",
    "test": "vitest run",
    "test:integration": "vitest run --testNamePattern='integration'"
  },
  "exports": {
    ".": "./dist/index.js",
    "./wasm": "./wasm/cdk_wasm.js"
  },
  "dependencies": {
    "@noble/secp256k1": "^2.1.0",
    "better-sqlite3": "^11.8.1",
    "express": "^5.2.1",
    "figlet": "^1.8.0",
    "yaml": "^2.7.0"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.0",
    "@types/express": "^5.0.0",
    "@types/figlet": "^1.7.0",
    "@types/node": "^22.10.0",
    "tsx": "^4.20.6",
    "typescript": "^5.8.2",
    "vitest": "^3.2.4"
  }
}
